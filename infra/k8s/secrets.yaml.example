# ============================================================
# Secret 模板（生产部署前必须替换所有值）
# 详见 SPEC §3.10.6 / ADR-0010
#
# 部署步骤：
#   1. cp secrets.yaml.example secrets.yaml
#   2. 用 sed / kubectl create secret 替换所有占位值
#   3. kubectl apply -f secrets.yaml（不要提交 secrets.yaml 到 git）
#
# 生产环境强烈建议改用：
#   - External Secrets Operator + Vault / AWS Secrets Manager
#   - Sealed Secrets（bitnami-labs/sealed-secrets）
#   - SOPS + Kustomize
# 详见 docs/MIGRATION.md §3
# ============================================================
apiVersion: v1
kind: Secret
metadata:
  name: a2a-prod-secrets
  namespace: a2a-prod
  labels:
    app.kubernetes.io/part-of: a2a-prod
type: Opaque
stringData:
  # ---- LiteLLM ----
  LITELLM_MASTER_KEY: "sk-a2a-prod-CHANGE-ME-32-bytes-random"

  # ---- 三家 LLM API Key ----
  # R2 修复（GLM 2026-06-18 review2）：MiniMax_API_KEY / MiniMax_API_BASE 改为全大写
  # MINIMAX_API_KEY / MINIMAX_API_BASE，与 02-configmap.yaml litellm config +
  # docker-compose env 保持一字不差。LiteLLM 的 os.environ/ 是字面匹配，混大小写会路由失败。
  GLM_API_KEY: "REPLACE_ME_glm_api_key"
  GLM_API_BASE: "https://open.bigmodel.cn/api/paas/v4/"
  DEEPSEEK_API_KEY: "REPLACE_ME_deepseek_api_key"
  DEEPSEEK_API_BASE: "https://api.deepseek.com/v1"
  MINIMAX_API_KEY: "REPLACE_ME_minimax_api_key"
  MINIMAX_API_BASE: "https://api.minimax.chat/v1"

  # ---- Langfuse ----
  LANGFUSE_INIT_USER_PASSWORD: "REPLACE_ME_admin_password"
  LANGFUSE_INIT_PROJECT_PUBLIC_KEY: "pk-lf-CHANGE-ME"
  LANGFUSE_INIT_PROJECT_SECRET_KEY: "sk-lf-CHANGE-ME"
  NEXTAUTH_SECRET: "REPLACE_ME_nextauth_random_32_bytes"
  CLICKHOUSE_PASSWORD: "REPLACE_ME_clickhouse_password"
  S3_ACCESS_KEY_ID: "REPLACE_ME_minio_user"
  S3_SECRET_ACCESS_KEY: "REPLACE_ME_minio_password"

  # ---- 内部数据库（Langfuse / ClickHouse / MinIO） ----
  POSTGRES_PASSWORD: "REPLACE_ME_postgres_password"
  MINIO_ROOT_PASSWORD: "REPLACE_ME_minio_root_password"
  REDIS_PASSWORD: "REPLACE_ME_redis_password"

  # ---- 业务侧 ----
  ORCHESTRATOR_API_KEY: "sk-a2a-prod-orch-CHANGE-ME"  # 可选，不设则用 LITELLM_MASTER_KEY

  # ---- Langfuse 内部组件的完整 URL（含密码，K8s ConfigMap 不支持变量展开）----
  # ⚠️ 部署前必须把 REPLACE_ME_postgres_password 替换为真实值
  DATABASE_URL: "postgresql://postgres:REPLACE_ME_postgres_password@langfuse-postgres:5432/postgres"
  REDIS_URL: "redis://:REPLACE_ME_redis_password@langfuse-redis:6379"
