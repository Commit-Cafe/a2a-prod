# ============================================================
# Open WebUI 独立 compose 环境变量模板
# 复制为 .env 并填入真实值；.env 已在 .gitignore 中
# ============================================================

# ---- Open WebUI 监听端口（宿主机侧）----
OPEN_WEBUI_PORT=8080

# ---- OpenAI 兼容端点（指向 orchestrator）----
# 容器内访问必须用 service 名（orchestrator），不能用 localhost
OPENAI_API_BASE_URL=http://orchestrator:12080/v1

# ---- Bearer Token（与 LITELLM_MASTER_KEY 保持一致）----
# 兜底：未设 OPENAI_API_KEY 时用 LITELLM_MASTER_KEY
OPENAI_API_KEY=
LITELLM_MASTER_KEY=sk-a2a-prod-litellm-master-key-change-me

# ---- 时区 ----
TZ=UTC
